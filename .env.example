# Copy to .env and update secret values.
LLM_MODEL=openai/gpt-oss-120b
LLM_PROXY_URL=http://ai-server.dream-flow.com:30000/v1
LLM_PROXY_API_KEY=dream-flow
OPENAI_API_KEY=dream-flow
OPENAI_BASE_URL=http://ai-server.dream-flow.com:30000/v1

LITELLM_PORT=4010
LITELLM_DB_PORT=5432
LITELLM_DB_PASSWORD=litellm
LITELLM_NUM_WORKERS=1
LITELLM_MASTER_KEY=change-this-master-key

ENV=prod
# Public-facing URLs of the Supabase API gateway (Kong) and the Process-GPT
# frontend. Change <localhost> to your machine's reachable host/IP when you
# expose the stack outside this machine (e.g. http://192.168.1.10:54321).
API_EXTERNAL_URL=http://localhost:54321
SITE_URL=http://localhost:8080
SUPABASE_URL=http://localhost:54321
SUPABASE_PUBLIC_URL=http://localhost:54321
# Used by services running INSIDE the docker compose network to reach Supabase Kong.
SUPABASE_INTERNAL_URL=http://kong:8000

# =====================================================================
# SUPABASE DEV DEFAULTS (Supabase self-hosting reference values)
# ---------------------------------------------------------------------
# JWT_SECRET below is the 32+ char string that signs the ANON_KEY and the
# SERVICE_ROLE_KEY JWTs. The three values are a MATCHING SET — they must
# be replaced together (regenerate JWTs at https://supabase.com/docs/guides/self-hosting#api-keys).
# These work out-of-the-box for local development. ROTATE BEFORE PRODUCTION.
# =====================================================================
JWT_SECRET=your-super-secret-jwt-token-with-at-least-32-characters-long
ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyAgCiAgICAicm9sZSI6ICJhbm9uIiwKICAgICJpc3MiOiAic3VwYWJhc2UtZGVtbyIsCiAgICAiaWF0IjogMTY0MTc2OTIwMCwKICAgICJleHAiOiAxNzk5NTM1NjAwCn0.dc_X5iR_VP_qT0zsiyj_I_OZ2T9FtRU2BBNWN8Bu4GE
SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyAgCiAgICAicm9sZSI6ICJzZXJ2aWNlX3JvbGUiLAogICAgImlzcyI6ICJzdXBhYmFzZS1kZW1vIiwKICAgICJpYXQiOiAxNjQxNzY5MjAwLAogICAgImV4cCI6IDE3OTk1MzU2MDAKfQ.DaYlNEoUrrEn2Ig7tqibS-PHK5vgusbcbo7X36XVt4Q
JWT_EXPIRY=3600
SECRET_KEY_BASE=UpNVntn3cDxHJpq99YMc1T1AQgQpc8kfYTuRgBiYa15BLrx8etQoXz3gZv1/u2oq
PGRST_DB_SCHEMAS=public,storage,graphql_public

STUDIO_PORT=3001
KONG_HTTP_PORT=54321
KONG_HTTPS_PORT=8443

POSTGRES_HOST=db
POSTGRES_PORT=5432
POSTGRES_DB=postgres
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your-super-secret-and-long-postgres-password
DB_HOST=db
DB_PORT=5432
DB_NAME=postgres
DB_USER=postgres
DB_PASSWORD=your-super-secret-and-long-postgres-password

SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_SERVER=
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_ADMIN_EMAIL=admin@example.com
SMTP_SENDER_NAME=Process-GPT
ENABLE_EMAIL_SIGNUP=true
ENABLE_ANONYMOUS_USERS=false
ENABLE_EMAIL_AUTOCONFIRM=false
ENABLE_PHONE_SIGNUP=false
ENABLE_PHONE_AUTOCONFIRM=false
DISABLE_SIGNUP=false
ADDITIONAL_REDIRECT_URLS=
MAILER_URLPATHS_INVITE=/auth/v1/verify
MAILER_URLPATHS_CONFIRMATION=/auth/v1/verify
MAILER_URLPATHS_RECOVERY=/auth/v1/verify
MAILER_URLPATHS_EMAIL_CHANGE=/auth/v1/verify
MAILER_SUBJECTS_CONFIRMATION=Confirm your email
MAILER_SUBJECTS_RECOVERY=Reset your password
MAILER_SUBJECTS_INVITE=You are invited
MAILER_SUBJECTS_EMAIL_CHANGE=Confirm email change
MAILER_TEMPLATES_CONFIRMATION=
MAILER_TEMPLATES_RECOVERY=
MAILER_TEMPLATES_INVITE=
MAILER_TEMPLATES_EMAIL_CHANGE=

STUDIO_DEFAULT_ORGANIZATION=default
STUDIO_DEFAULT_PROJECT=process-gpt
LOGFLARE_API_KEY=your-super-secret-and-long-logflare-key
LOGFLARE_PRIVATE_ACCESS_TOKEN=your-super-secret-and-long-logflare-private-token
IMGPROXY_ENABLE_WEBP_DETECTION=true
FUNCTIONS_VERIFY_JWT=false

NEO4J_URI=bolt://neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=password
NEO4J_HTTP_PORT=7474
NEO4J_BOLT_PORT=7687
NEO4J_AUTH=neo4j/password
NEO4J_PLUGINS=[]

KONG_TRUSTED_IPS=0.0.0.0/0,::/0
KONG_REAL_IP_FROM=0.0.0.0/0,::/0
KONG_REAL_IP_HEADER=X-Forwarded-For

# ---- Gateway (Nginx) --------------------------------------------------
GATEWAY_HTTP_PORT=8088

# ---- Optional service overrides --------------------------------------
ROBO_GLOSSARY_BACKEND_IMAGE=ghcr.io/uengine-oss/process-gpt-glossary-backend:latest
ROBO_GLOSSARY_BACKEND_PORT=5504

# ---- Optional API keys (leave blank if unused) -----------------------
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
TAVILY_API_KEY=
OPENAI_MODEL=gpt-4.1
